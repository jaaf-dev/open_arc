# Copia este archivo a .env y ajusta los valores:
#   cp .env.example .env
#
# Modelo por defecto: Qwen2.5-7B-Instruct (~4.5 GB INT4, agente OpenCode probado)

OPENARC_API_KEY=cambiar-por-clave-segura
OPENARC_AUTOLOAD_MODEL=qwen2.5-7b-instruct

# Debe coincidir con OPENARC_API_KEY para que Open WebUI conecte a OpenArc
OPENAI_API_KEY=cambiar-por-clave-segura
WEBUI_SECRET_KEY=cambiar-por-clave-segura
